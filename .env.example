# NEPS Data Platform — ETL configuration
# Copy to .env for local development

APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://neps:neps_password@localhost:5432/neps_db

# REDCap — development (mock replaces production REDCap)
REDCAP_API_URL=http://localhost:8000/api/redcap
REDCAP_API_TOKEN=mock_token_for_development_only
REDCAP_MOCK_ENABLED=true
REDCAP_PROJECT_ID=NEPS-2025

# REDCap — production (uncomment when real credentials are available)
# REDCAP_API_URL=https://kcird.org/api/
# REDCAP_API_TOKEN_FILE=/run/secrets/redcap_api_token
# REDCAP_MOCK_ENABLED=false
