# NEPS Digital — Environment Configuration
# Copy this to .env and fill in real values for production

# Application
APP_NAME=NEPS Digital
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql://neps:neps_password@postgres:5432/neps_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# REDCap (MOCK for development)
REDCAP_API_URL=http://neps-backend:8000/api/redcap
REDCAP_API_TOKEN=mock_token_for_development_only
REDCAP_PROJECT_ID=NEPS-2025
REDCAP_MOCK_ENABLED=true

# When you get real REDCap credentials, update to:
# REDCAP_API_URL=https://kcird.org/api/
# REDCAP_API_TOKEN=your_real_32_char_token_here
# REDCAP_MOCK_ENABLED=false

# JWT Authentication
JWT_ALGORITHM=ES256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=50

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
